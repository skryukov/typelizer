{
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier"
    },
    "username": {
      "type": "string"
    },
    "active": {
      "type": "boolean"
    },
    "name": {
      "type": "string"
    },
    "invitor": {
      "oneOf": [
        {
          "$ref": "#/components/schemas/OjSerializersUser"
        },
        {
          "type": "null"
        }
      ]
    },
    "posts": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/OjSerializersPost"
      }
    },
    "firstName": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "username",
    "active",
    "name",
    "invitor",
    "posts",
    "firstName"
  ]
}