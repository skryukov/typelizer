{
  "type": "object",
  "properties": {
    "id": {
      "type": [
        "string",
        "null"
      ],
      "description": "Unique identifier"
    },
    "username": {
      "type": "string"
    },
    "active": {
      "type": "boolean"
    },
    "name": {
      "type": "string"
    },
    "first_name": {
      "type": "string"
    },
    "full_name": {
      "type": "string"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "invitor": {
      "oneOf": [
        {
          "$ref": "#/components/schemas/AmsUser"
        },
        {
          "type": "null"
        }
      ]
    },
    "posts": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/AmsPost"
      }
    }
  },
  "required": [
    "id",
    "username",
    "active",
    "name",
    "first_name",
    "full_name",
    "updated_at",
    "invitor",
    "posts"
  ]
}