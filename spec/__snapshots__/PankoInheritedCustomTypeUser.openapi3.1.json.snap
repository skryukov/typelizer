{
  "type": "object",
  "properties": {
    "id": {
      "type": [
        "number",
        "null"
      ],
      "description": "Unique identifier"
    },
    "username": {
      "type": "string"
    },
    "active": {
      "type": "boolean"
    },
    "name": {
      "type": "string"
    },
    "first_name": {
      "type": "string"
    },
    "posts": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/PankoPost"
      }
    },
    "invitor": {
      "oneOf": [
        {
          "$ref": "#/components/schemas/PankoUser"
        },
        {
          "type": "null"
        }
      ]
    },
    "latest_post": {
      "oneOf": [
        {
          "$ref": "#/components/schemas/PankoPost"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "required": [
    "username",
    "active",
    "name",
    "first_name",
    "posts",
    "invitor",
    "latest_post"
  ]
}