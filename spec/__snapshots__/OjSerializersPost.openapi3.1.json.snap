{
  "type": "object",
  "properties": {
    "id": {
      "type": "integer"
    },
    "title": {
      "type": [
        "string",
        "null"
      ]
    },
    "category": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "news",
        "article",
        "blog",
        null
      ]
    },
    "body": {
      "type": [
        "string",
        "null"
      ]
    },
    "published_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "user": {
      "$ref": "#/components/schemas/OjSerializersUser"
    },
    "created_by": {
      "$ref": "#/components/schemas/OjSerializersUser"
    },
    "previous_post": {
      "$ref": "#/components/schemas/OjSerializersPost"
    },
    "name": {
      "type": "string",
      "deprecated": true
    }
  },
  "required": [
    "id",
    "user",
    "created_by",
    "previous_post",
    "name"
  ]
}