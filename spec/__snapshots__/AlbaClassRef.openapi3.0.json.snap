{
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier"
    },
    "title": {
      "type": "string",
      "nullable": true
    },
    "reviewer": {
      "allOf": [
        {
          "$ref": "#/components/schemas/AlbaUser"
        }
      ],
      "nullable": true
    },
    "editor": {
      "$ref": "#/components/schemas/AlbaUser"
    },
    "approver": {
      "allOf": [
        {
          "$ref": "#/components/schemas/AlbaUser"
        }
      ],
      "nullable": true
    },
    "commentable": {
      "anyOf": [
        {
          "$ref": "#/components/schemas/AlbaUser"
        },
        {
          "$ref": "#/components/schemas/AlbaComment"
        }
      ]
    },
    "mixed_ref": {
      "anyOf": [
        {
          "$ref": "#/components/schemas/AlbaUser"
        },
        {
          "$ref": "#/components/schemas/AlbaComment"
        }
      ]
    },
    "contributors": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/AlbaUser"
      },
      "nullable": true
    }
  },
  "required": [
    "id",
    "editor",
    "approver",
    "commentable",
    "mixed_ref",
    "contributors"
  ]
}