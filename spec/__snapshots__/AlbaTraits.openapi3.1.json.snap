{
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier"
    },
    "invitor": {
      "oneOf": [
        {
          "$ref": "#/components/schemas/AlbaTraits"
        },
        {
          "type": "null"
        }
      ]
    },
    "posts": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/AlbaPost"
      }
    },
    "latest_post": {
      "oneOf": [
        {
          "$ref": "#/components/schemas/AlbaPost"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "required": [
    "id",
    "invitor",
    "posts",
    "latest_post"
  ]
}