{
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier"
    },
    "username": {
      "type": "string"
    },
    "active": {
      "type": "boolean"
    },
    "name": {
      "type": "string"
    },
    "invitor": {
      "allOf": [
        {
          "$ref": "#/components/schemas/OjSerializersUser"
        }
      ],
      "nullable": true
    },
    "posts": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/OjSerializersPost"
      }
    },
    "first_name": {
      "type": "string"
    },
    "full_name": {
      "type": "string"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "id",
    "username",
    "active",
    "name",
    "invitor",
    "posts",
    "first_name",
    "full_name",
    "updated_at"
  ]
}