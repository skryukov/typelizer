{
  "type": "object",
  "properties": {
    "invitor": {
      "allOf": [
        {
          "$ref": "#/components/schemas/AlbaTraits"
        },
        {
          "$ref": "#/components/schemas/AlbaTraitsBasicTrait"
        }
      ],
      "nullable": true
    },
    "posts": {
      "type": "array",
      "items": {
        "allOf": [
          {
            "$ref": "#/components/schemas/AlbaPost"
          },
          {
            "$ref": "#/components/schemas/AlbaPostDetailsTrait"
          },
          {
            "$ref": "#/components/schemas/AlbaPostWithAuthorTrait"
          }
        ]
      }
    },
    "username": {
      "type": "string"
    }
  },
  "required": [
    "invitor",
    "posts",
    "username"
  ]
}